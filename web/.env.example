NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_ENCRYPTION_SALT=set_a_long_random_salt_value

# Indian Kanoon API (Optional - for legal database integration)
INDIAN_KANOON_API_TOKEN=your_api_token_here
INDIAN_KANOON_API_URL=https://api.indiankanoon.org

# Feature Flags
ENABLE_KNOWLEDGE_BASE=true

# Razorpay for payments (optional for MVP)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Billing plan prices are configured in src/lib/billing/plans.ts

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron protection (required in production for scheduler endpoints)
CRON_SECRET=replace_with_a_long_random_secret

# Optional: set only if your host requires explicit browser path for Puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
